<%- layout("./layouts/boilerplate.ejs") %>

    <body>

        <section class="page-panel hero-panel">
            <h2 class="page-title">
                <%= listing.title %>
            </h2>
        </section>

        <div class="row">
            <div class="col-12 col-md-10 col-lg-6 mx-auto">

                <div class="card shadow-sm detail-card">
                    <img src="<%= listing.image.url %>" class="card-img-top show-img">
                    <div class="card-body">
                        <div class="card-text info-stack">

                            <% if(listing.owner) { %>
                                <div class="owner-box">
                                    <p class="owner-name">
                                        👤 <%= listing.owner.username %>
                                    </p>
                                    <p class="owner-email">
                                        <%= listing.owner.email %>
                                    </p>
                                </div>
                                <% } %>

                                    <p>
                                        <%= listing.description %>
                                    </p>

                                    <p><b>Price:</b> ₹ <%= listing.price.toLocaleString("en-IN") %>
                                    </p>
                                    <p><b>Location:</b>
                                        <%= listing.location %>
                                    </p>
                                    <p><b>Country:</b>
                                        <%= listing.country %>
                                    </p>

                        </div>
                    </div>
                </div>

                <% if(currUser && listing.owner && String(currUser._id)===String(listing.owner._id)) { %>
                    <div class="btns mb-3">
                        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark action-btn">Edit</a>

                        <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
                            <button type="submit" class="btn btn-dark action-btn">Delete</button>
                        </form>
                    </div>
                    <% } %>

                <section class="map-section mt-4">
                    <div class="map-card form-shell">
                        <div class="map-heading">
                            <h5 class="mb-1 review-title">Location Map</h5>
                            <p class="map-subtitle mb-0"><%= listing.location %>, <%= listing.country %></p>
                        </div>
                        <div id="listing-map" class="listing-map" data-title="<%= listing.title %>"
                            data-location="<%= listing.location %>" data-country="<%= listing.country %>"></div>
                        <p id="map-status" class="map-status mb-0">Loading map...</p>
                    </div>
                </section>

            </div>
        </div>

        <div class="review-section mt-4">
            <div class="row">
                <div class="col-12 col-md-10 col-lg-6 mx-auto">
                    <div class="review-card form-shell">

                        <h5 class="mb-3 review-title">Leave a Review</h5>

                        <form action="/listings/<%= listing._id %>/reviews" method="POST" class="review-form">

                            <div class="mb-3">
                                <label class="form-label">Rating</label>
                                <input type="range" min="1" max="5" class="form-range review-range" name="review[rating]">
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Your Review</label>
                                <textarea name="review[comment]" class="form-control review-textarea" rows="3"
                                    placeholder="Write your experience..." required></textarea>
                            </div>

                            <button class="btn action-btn w-100">Submit Review</button>

                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== ALL REVIEWS ===== -->
        <% if(listing.reviews && listing.reviews.length> 0) { %>

            <div class="all-reviews mt-4 col-12 col-md-10 col-lg-6 mx-auto px-0">
                <h4 class="mb-3">All Reviews</h4>

                <% for(let review of listing.reviews) { %>
                    <div class="review-item card p-3 mb-2 shadow-sm">

                        <!-- REVIEW AUTHOR -->
                        <% if(review.author) { %>
                            <p class="review-author">
                                👤 <%= review.author.username %>
                            </p>
                            <% } %>

                                <!-- COMMENT -->
                                <p class="review-comment">
                                    <%= review.comment %>
                                </p>

                                <!-- FOOTER -->
                                <div class="review-footer d-flex justify-content-between align-items-center mt-2">

                                    <div class="review-rating">
                                        ⭐ <%= review.rating %>/5
                                    </div>

                                    <!-- DELETE BUTTON (AUTHOR OR LISTING OWNER) -->
                                    <% if( currUser && ( (review.author &&
                                        String(currUser.id)===String(review.author._id)) || (listing.owner &&
                                        String(currUser.id)===String(listing.owner._id)) ) ) { %>
                                        <form
                                            action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                                            method="POST">
                                            <button type="submit" class="btn btn-sm btn-outline-danger delete-btn">
                                                Delete
                                            </button>
                                        </form>
                                        <% } %>

                                </div>

                    </div>
                    <% } %>

            </div>

            <% } %>

    </body>
